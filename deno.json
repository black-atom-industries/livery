{
    "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
    "version": "0.3.0",
    "compilerOptions": {
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "jsxImportSourceTypes": "@types/react",
        "lib": [
            "deno.ns",
            "dom",
            "dom.iterable"
        ]
    },
    "tasks": {
        "dev": "deno run -A npm:@tauri-apps/cli dev",
        "build": "deno run -A npm:@tauri-apps/cli build",
        "vite:dev": "deno run -A npm:vite",
        "vite:build": "deno run -A npm:vite build",
        "check": "deno check src/**/*.ts src/**/*.tsx",
        "test": "deno test -P",
        "checks": "deno run -A scripts/checks-frontend.ts && deno run -A scripts/checks-backend.ts",
        "install-hooks": "cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit && echo 'Hooks installed.'",
        "test:perf-benchmark": "cd src-tauri && cargo run --bin perf-benchmark --release",
        "install:macos": "deno run -A npm:@tauri-apps/cli build && rm -rf /Applications/livery.app && cp -R src-tauri/target/release/bundle/macos/livery.app /Applications/livery.app"
    },
    "nodeModulesDir": "auto",
    "lint": {
        "exclude": [
            "src/routeTree.gen.ts",
            "src/bindings.ts"
        ]
    },
    "fmt": {
        "useTabs": false,
        "lineWidth": 100,
        "indentWidth": 4,
        "semiColons": true,
        "singleQuote": false,
        "exclude": [
            "CHANGELOG.md",
            "src-tauri/",
            "src/routeTree.gen.ts",
            "src/bindings.ts"
        ]
    },
    "test": {
        "permissions": {
            "env": true,
            "read": true,
            "write": true
        }
    },
    "imports": {
        "@base-ui/react": "npm:@base-ui/react@^1",
        "@black-atom/core": "jsr:@black-atom/core@^0.4.0",
        "@deno/vite-plugin": "npm:@deno/vite-plugin@^1",
        "@std/assert": "jsr:@std/assert@^1.0.0",
        "@std/path": "jsr:@std/path@^1.0.0",
        "@tanstack/store": "npm:@tanstack/store@^0.9",
        "@tanstack/react-store": "npm:@tanstack/react-store@^0.9",
        "@tanstack/react-query": "npm:@tanstack/react-query@^5",
        "@tanstack/react-router": "npm:@tanstack/react-router@^1",
        "@tanstack/router-plugin": "npm:@tanstack/router-plugin@^1",
        "@tanstack/react-devtools": "npm:@tanstack/react-devtools@^0",
        "@tanstack/react-query-devtools": "npm:@tanstack/react-query-devtools@^5",
        "@tanstack/react-router-devtools": "npm:@tanstack/react-router-devtools@^1",
        "@tanstack/react-hotkeys": "npm:@tanstack/react-hotkeys@^0.3.0",
        "react": "npm:react@^18.3.1",
        "@types/react": "npm:@types/react@^18.3.0",
        "react-dom": "npm:react-dom@^18.3.1",
        "@types/react-dom": "npm:@types/react-dom@^18.3.0",
        "vite": "npm:vite@^6",
        "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^4",
        "tailwindcss": "npm:tailwindcss@^4",
        "@tailwindcss/vite": "npm:@tailwindcss/vite@^4",
        "@tauri-apps/api": "npm:@tauri-apps/api@^2",
        "@tauri-apps/cli": "npm:@tauri-apps/cli@^2"
    }
}
